{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "lib": ["ESNext", "DOM"],
    "outDir": "dist",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "declarationMap": true,
  },
  "include": ["src/**/*", "bin/**/*"],
  "exclude": ["node_modules", "dist"],
}
